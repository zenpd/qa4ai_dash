{
  "uid": "qe-correctness",
  "title": "QE for AI — Correctness & Evaluation",
  "tags": [
    "qe-pillar",
    "qe",
    "quality"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "style": "dark",
  "description": "ZenLabs Foundry · Correctness & Evaluation",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [
    {
      "asDropdown": true,
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "qe-pillar"
      ],
      "title": "Pillar Navigation",
      "tooltip": "Switch between pillars",
      "type": "dashboards",
      "url": ""
    }
  ],
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Project",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(phoenix_project_present, project_name)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": {}
      },
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(temporal_workflow_active, namespace)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Avg Eval Score",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "avg(phoenix_evaluator_score{project_name=~\"$project\"}) * 100",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#E24B4A",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 70
              },
              {
                "color": "#1D9E75",
                "value": 85
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "LLM Trace Coverage",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(clamp_max(count(phoenix_trace_count{project_name=~\"$project\"} > 0) / count(phoenix_trace_count{project_name=~\"$project\"}) * 100, 100)) or vector(0)",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#E24B4A",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 50
              },
              {
                "color": "#1D9E75",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Hallucination Rate",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - avg(phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*factual.*|.*grounding.*\"})) * 100",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#1D9E75",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 5
              },
              {
                "color": "#E24B4A",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cost / Analysis",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "((sum(phoenix_token_count_prompt{project_name=~\"$project\"}) * 2.5 + sum(phoenix_token_count_completion{project_name=~\"$project\"}) * 10) / 1000000 / clamp_min(sum(phoenix_trace_count{project_name=~\"$project\"}), 1)) or vector(0)",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#1D9E75",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 10
              },
              {
                "color": "#E24B4A",
                "value": 50
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "PEP False-Positive",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(1 - avg(phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*pep.*\"})) * 100",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#1D9E75",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 5
              },
              {
                "color": "#E24B4A",
                "value": 15
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Workflow Durability",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(sum(temporal_workflow_completed_total{namespace=~\"$namespace\"}) / clamp_min(sum(temporal_workflow_completed_total{namespace=~\"$namespace\"}) + sum(temporal_workflow_failed_total{namespace=~\"$namespace\"}) + sum(temporal_workflow_timed_out_total{namespace=~\"$namespace\"}), 1) * 100) or vector(0)",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#E24B4A",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 80
              },
              {
                "color": "#1D9E75",
                "value": 95
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "01 · Correctness & Evaluation — LLM-as-judge scores across 9 evaluators",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Evaluator Scores — Current",
      "description": "Phoenix LLM-as-judge evaluator scores (0“1 scale). Bars colored green when passing threshold, red when below.",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 12
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\"}",
          "legendFormat": "{{evaluator_name}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#E24B4A",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 0.8
              },
              {
                "color": "#1D9E75",
                "value": 0.85
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "stacking": "none",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "lastNotNull"
            ]
          }
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Evaluator Score Trend",
      "description": "Score trend over time for all evaluators — tracks improvement across model versions.",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 12
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*pep.*\"}",
          "legendFormat": "pep_accuracy",
          "refId": "A"
        },
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*fatca.*\"}",
          "legendFormat": "fatca_accuracy",
          "refId": "B"
        },
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*aml.*\"}",
          "legendFormat": "aml_decision_quality",
          "refId": "C"
        },
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*kyc.*\"}",
          "legendFormat": "kyc_quality",
          "refId": "D"
        },
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*factual.*|.*grounding.*\"}",
          "legendFormat": "factual_grounding",
          "refId": "E"
        },
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*escalation.*\"}",
          "legendFormat": "escalation_quality",
          "refId": "F"
        },
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*step.*\"}",
          "legendFormat": "step_completion",
          "refId": "G"
        },
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*response.*\"}",
          "legendFormat": "response_quality",
          "refId": "H"
        },
        {
          "expr": "phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*doc.*|.*verification.*\"}",
          "legendFormat": "doc_verification",
          "refId": "I"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0.5,
          "max": 1.0,
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true,
            "fillOpacity": 5
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 13,
      "type": "text",
      "title": "CI Gate Thresholds & Current Status",
      "description": "Reference table: evaluator thresholds, gate levels, and pass/fail status.",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 24,
        "h": 9
      },
      "options": {
        "mode": "html",
        "content": "<table class='gt'><thead><tr><th>Evaluator</th><th>Min Threshold</th><th>Gate</th><th>Description</th></tr></thead><tbody><tr><td>eval.pep_accuracy</td><td>0.95</td><td><span class='bd bbl'>Block</span></td><td>PEP screening accuracy — false positives must be minimised</td></tr><tr><td>eval.fatca_accuracy</td><td>0.95</td><td><span class='bd bbl'>Block</span></td><td>FATCA classification accuracy for US tax compliance</td></tr><tr><td>eval.aml_decision_quality</td><td>0.90</td><td><span class='bd bbl'>Block</span></td><td>AML decision quality — must not miss suspicious activity</td></tr><tr><td>eval.escalation_quality</td><td>0.88</td><td><span class='bd bbl'>Block</span></td><td>Correct escalation routing and priority assignment</td></tr><tr><td>eval.factual_grounding</td><td>0.85</td><td><span class='bd bbl'>Block</span></td><td>LLM output grounded in source data — anti-hallucination</td></tr><tr><td>eval.kyc_quality</td><td>0.85</td><td><span class='bd bwa'>Warn</span></td><td>KYC data extraction and verification quality</td></tr><tr><td>eval.document_verification</td><td>0.85</td><td><span class='bd bwa'>Warn</span></td><td>Document authenticity and data extraction accuracy</td></tr><tr><td>eval.step_completion</td><td>0.80</td><td><span class='bd bwa'>Warn</span></td><td>Workflow step completion and ordering correctness</td></tr><tr><td>eval.response_quality</td><td>0.75</td><td><span class='bd bin'>Info</span></td><td>Overall LLM response quality and coherence</td></tr></tbody></table>"
      }
    }
  ]
}
