    "list": [
      {
        "name": "project",
        "label": "Project / App",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": {
          "query": "label_values(phoenix_project_present, project_name)",
          "refId": "StandardVariableQuery"
