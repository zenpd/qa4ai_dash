      "title": "Avg Eval Score",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(avg(phoenix_evaluator_score{project_name=~\"$project\"}) * 100) or vector(0)",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#E24B4A",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 70
              },
              {
                "color": "#1D9E75",
                "value": 85
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
