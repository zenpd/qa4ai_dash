# Pre-built dist/ is copied directly — build runs locally via `npm run build`
# before this Dockerfile is invoked. This avoids QEMU/esbuild crashes on ARM hosts.
FROM nginx:1.27-alpine
COPY dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
