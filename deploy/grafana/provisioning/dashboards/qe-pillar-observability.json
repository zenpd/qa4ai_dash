      "type": "piechart",
      "title": "Span Type Distribution",
      "description": "Distribution of span kinds from recent traces — LLM, Chain, Tool, Retriever, Embedding, HTTP.",
      "gridPos": {
        "x": 0,
        "y": 49,
        "w": 12,
        "h": 11
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "phoenix_span_type_percent{project_name=~\"$project\"}",
          "legendFormat": "{{span_kind}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "LLM"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#378ADD",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "CHAIN"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#7F77DD",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "TOOL"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#1D9E75",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "RETRIEVER"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#EF9F27",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "EMBEDDING"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#D4537E",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "AGENT"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#FF6B6B",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "pieType": "donut",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
