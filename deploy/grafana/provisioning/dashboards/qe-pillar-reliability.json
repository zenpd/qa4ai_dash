    {
      "id": 20,
      "type": "row",
      "title": "02 · Reliability & Durability — Workflow resilience, fault injection, coverage",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "barchart",
      "title": "Workflow Execution Status",
      "description": "Temporal workflow counts by status per namespace — Running, Completed, Failed, TimedOut, Canceled.",
      "gridPos": {
        "x": 0,
        "y": 27,
        "w": 12,
        "h": 10
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "temporal_workflow_completed_total{}",
          "legendFormat": "Completed — {{namespace}}",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "temporal_workflow_failed_total{}",
          "legendFormat": "Failed — {{namespace}}",
          "instant": true,
          "refId": "B"
        },
        {
          "expr": "temporal_workflow_active{}",
          "legendFormat": "Running — {{namespace}}",
          "instant": true,
          "refId": "C"
        },
        {
          "expr": "temporal_workflow_timed_out_total{}",
          "legendFormat": "TimedOut — {{namespace}}",
          "instant": true,
          "refId": "D"
        },
        {
          "expr": "temporal_workflow_canceled_total{}",
          "legendFormat": "Canceled — {{namespace}}",
          "instant": true,
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 80
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "Completed.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#1D9E75",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "Failed.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#E24B4A",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "Running.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#378ADD",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "TimedOut.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#EF9F27",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "Canceled.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#888780",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "always",
        "barWidth": 0.7,
        "stacking": "none",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "lastNotNull"
            ]
          }
        }
      ]
    },
    {
      "id": 22,
      "type": "text",
      "title": "Fault Injection — QE Test Results",
      "description": "Fault injection test results from QE testing suite.",
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 12,
        "h": 10
      },
      "options": {
        "mode": "html",
        "content": "<table class='ft'><thead><tr><th>Fault Scenario</th><th>Expected Behaviour</th><th>Result</th></tr></thead><tbody><tr><td>LLM timeout (&gt;5 min)</td><td>Retry Ã—3 then compensate</td><td class='ps'>Pass âœ“</td></tr><tr><td>Worker kill -9 mid-run</td><td>Replay from checkpoint</td><td class='ps'>Pass âœ“</td></tr><tr><td>Redis down</td><td>Retry; DB persist succeeds</td><td class='ps'>Pass âœ“</td></tr><tr><td>DB constraint violation</td><td>Non-retryable + compensate</td><td class='ps'>Pass âœ“</td></tr><tr><td>OpenAI 429 rate limit</td><td>Backoff 2sâ†’4sâ†’8s</td><td class='ps'>Pass âœ“</td></tr><tr><td>Namespace bootstrap race</td><td>Idempotent registration</td><td class='ps'>Pass âœ“</td></tr></tbody></table>"
