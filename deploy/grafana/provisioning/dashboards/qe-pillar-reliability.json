{
  "uid": "qe-reliability",
  "title": "QE for AI — Reliability & Durability",
  "tags": [
    "qe-pillar",
    "qe",
    "quality"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "style": "dark",
  "description": "ZenLabs Foundry · Reliability & Durability",
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "links": [
    {
      "asDropdown": true,
      "icon": "dashboard",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "qe-pillar"
      ],
      "title": "Pillar Navigation",
      "tooltip": "Switch between pillars",
      "type": "dashboards",
      "url": ""
    }
  ],
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "Agentic App",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-ds"
        },
        "query": {
          "query": "label_values(phoenix_project_present, project_name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1,
        "hide": 0,
        "skipUrlSync": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Avg Eval Score",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(avg(phoenix_evaluator_score{project_name=~\"$project\"}) * 100) or vector(0)",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#E24B4A",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 70
              },
              {
                "color": "#1D9E75",
                "value": 85
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "LLM Trace Coverage",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "(clamp_max((count(phoenix_trace_count{project_name=~\"$project\"} > 0) or vector(0)) / clamp_min(count(phoenix_trace_count{project_name=~\"$project\"}),1) * 100, 100)) or vector(0)",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#E24B4A",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 50
              },
              {
                "color": "#1D9E75",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Hallucination Rate",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "((1 - avg(phoenix_evaluator_score{project_name=~\"$project\", evaluator_name=~\".*factual.*|.*grounding.*\"})) * 100) or vector(0)",
          "legendFormat": "",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#1D9E75",
                "value": null
              },
              {
                "color": "#EF9F27",
                "value": 5
              },
              {
                "color": "#E24B4A",
                "value": 10
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
