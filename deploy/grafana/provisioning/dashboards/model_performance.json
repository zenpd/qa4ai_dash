{
  "uid": "model-performance",
  "title": "Model Performance (Phoenix)",
  "tags": ["phoenix", "ml", "model"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "model_name",
        "label": "Model",
        "type": "query",
        "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
        "query": "label_values(phoenix_model_accuracy, model_name)",
        "refresh": 2,
        "multi": false,
        "includeAll": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Accuracy",
      "type": "stat",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "phoenix_model_accuracy{model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Precision",
      "type": "stat",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "phoenix_model_precision{model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Recall",
      "type": "stat",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "phoenix_model_recall{model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "F1 Score",
      "type": "stat",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "phoenix_model_f1_score{model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Drift Score",
      "type": "stat",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "phoenix_model_drift_score{model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.03 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Calibration Error",
      "type": "stat",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "expr": "phoenix_model_calibration_error{model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Drift Score Over Time",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "phoenix_model_drift_score{model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "line" }
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Calibration Error Over Time",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "phoenix_model_calibration_error{model_name=~\"$model_name\"}",
          "legendFormat": "{{model_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    }
  ]
}
