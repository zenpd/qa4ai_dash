{
  "uid": "system-health",
  "title": "System Health",
  "tags": ["system", "infrastructure"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "gauge",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "targets": [
        { "expr": "system_cpu_usage_percent", "legendFormat": "CPU" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage (%)",
      "type": "gauge",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "targets": [
        { "expr": "system_memory_usage_percent", "legendFormat": "Memory" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Available Memory (GB)",
      "type": "stat",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 6 },
      "targets": [
        { "expr": "system_memory_available_gb", "legendFormat": "Available" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decgbytes", "color": { "mode": "fixed", "fixedColor": "blue" } }
      }
    },
    {
      "id": 4,
      "title": "Disk Usage (%)",
      "type": "gauge",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 6 },
      "targets": [
        { "expr": "system_disk_usage_percent", "legendFormat": "Disk" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        { "expr": "system_cpu_usage_percent", "legendFormat": "CPU %" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 6,
      "title": "Memory Usage Over Time",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        { "expr": "system_memory_usage_percent", "legendFormat": "Memory %" },
        { "expr": "system_memory_available_gb", "legendFormat": "Available GB" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "Network Traffic",
      "type": "timeseries",
      "datasource": { "uid": "prometheus-ds", "type": "prometheus" },
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "targets": [
        { "expr": "rate(system_network_bytes_sent_total[1m])", "legendFormat": "Sent (bytes/s)" },
        { "expr": "rate(system_network_bytes_recv_total[1m])", "legendFormat": "Received (bytes/s)" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } }
      }
    }
  ]
}
